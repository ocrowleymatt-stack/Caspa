{
  "name": "caspa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --external:uuid --external:express --external:dotenv --external:firebase --external:@google/generative-ai --sourcemap --outfile=dist/server.cjs",
