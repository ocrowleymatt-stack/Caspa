rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(projectData) {
      return isSignedIn() && projectData.ownerId == request.auth.uid;
    }

    function hasCollaborators(projectData) {
      return projectData.collaborators != null && projectData.collaborators is list;
    }

    function isCollaborator(projectData) {
      return isSignedIn() && hasCollaborators(projectData) && request.auth.uid in projectData.collaborators;
    }

    function canAccessProject(projectData) {
      return projectData != null && (isOwner(projectData) || isCollaborator(projectData));
    }

    function projectData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function canAccessProjectById(projectId) {
      return canAccessProject(projectData(projectId));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function immutableProjectIdentityPreserved() {
      return incoming().id == existing().id &&
             incoming().ownerId == existing().ownerId &&
             incoming().createdAt == existing().createdAt;
    }

    function ownerCanUpdateProject() {
      return isSignedIn() &&
             isOwner(existing()) &&
             immutableProjectIdentityPreserved() &&
             incoming().diff(existing()).affectedKeys().hasOnly([
               'title', 'type', 'maturity', 'genre', 'premise', 'tone',
               'collaborators', 'lastModified', 'stats', 'critiques',
               'targetPrize', 'prizeAssessments', 'sourceMaterials',
               'externalReviews', 'isPublic', 'publicId', 'targetWordCount',
               'publishing', 'updatedAt', 'primaryProvider',
               'characters', 'plotNodes', 'chapters', 'research',
               'outline', 'architecture', 'analysis', 'manuscriptAnalysis',
               'continuityReport', 'overhaul', 'overhaulLog', 'fixProgress',
               'settings', 'metadata', 'notes', 'lastOverhaulAt'
             ]);
    }

    // --- Entity Validations ---
    function isValidProjectOnCreate(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 500 &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             (data.collaborators == null || data.collaborators is list) &&
             (data.isPublic == null || data.isPublic is bool);
    }

    function isValidChapter(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 500 &&
             data.content is string && data.content.size() <= 1048576 &&
             data.order is number;
    }

    // --- Rules ---

    // Projects
    match /projects/{projectId} {
      allow get: if (isSignedIn() && canAccessProject(existing())) || existing().isPublic == true;
      allow list: if isSignedIn() && canAccessProject(existing());
      
      allow create: if isSignedIn() &&
                      isValidId(projectId) &&
                      isValidProjectOnCreate(incoming()) &&
                      incoming().ownerId == request.auth.uid &&
                      incoming().createdAt is number;

      allow update: if ownerCanUpdateProject();

      allow delete: if isSignedIn() && isOwner(existing());

      // Sub-collections
      match /characters/{charId} {
        allow read, write: if canAccessProjectById(projectId);
      }

      match /plotNodes/{nodeId} {
        allow read, write: if canAccessProjectById(projectId);
      }

      match /chapters/{chapterId} {
        allow get, list: if canAccessProjectById(projectId) || projectData(projectId).isPublic == true;
        allow write: if canAccessProjectById(projectId);
      }

      match /research/{noteId} {
        allow read, write: if canAccessProjectById(projectId);
      }

      match /sourceMaterials/{sourceId} {
        allow read, write: if canAccessProjectById(projectId);
      }

      match /presence/{userId} {
        allow read: if canAccessProjectById(projectId);
        allow write: if isSignedIn() && userId == request.auth.uid && canAccessProjectById(projectId);
      }
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow write: if isSignedIn() && userId == request.auth.uid;
    }
  }
}
