rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(projectData) {
      return isSignedIn() && projectData != null && projectData.get('ownerId', '') == request.auth.uid;
    }

    function isCollaborator(projectData) {
      return isSignedIn() && projectData != null && 
             projectData.get('collaborators', []) is list &&
             request.auth.uid in projectData.get('collaborators', []);
    }

    function canAccessProject(projectData) {
      return isOwner(projectData) || isCollaborator(projectData);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidProject(data) {
      return data.get('id', '') is string && data.get('id', '').size() <= 128 &&
             data.get('title', '') is string && data.get('title', '').size() <= 500 &&
             data.get('ownerId', '') is string && data.get('ownerId', '').size() <= 128;
    }

    function isValidChapter(data) {
      return data.get('id', '') is string && data.get('id', '').size() <= 128 &&
             data.get('title', '') is string && data.get('title', '').size() <= 500 &&
             data.get('content', '') is string && data.get('content', '').size() <= 2097152 && // Increased to 2MB as failsafe
             data.get('order', 0) is number &&
             data.get('updatedAt', 0) is number;
    }

    // --- Rules ---

    // Projects
    match /projects/{projectId} {
      allow get: if isSignedIn() && (isOwner(existing()) || isCollaborator(existing())) || existing().isPublic == true;
      allow list: if isSignedIn() && (existing().ownerId == request.auth.uid || request.auth.uid in existing().collaborators);
      
      allow create: if isSignedIn() && 
                      isValidId(projectId) &&
                      isValidProject(incoming()) &&
                      incoming().ownerId == request.auth.uid &&
                      incoming().createdAt is number;

      allow update: if isSignedIn() &&
                      isValidProject(incoming()) &&
                      isOwner(existing()) &&
                      incoming().ownerId == existing().ownerId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'title', 'type', 'maturity', 'genre', 'premise', 'tone', 
                        'collaborators', 'lastModified', 'stats', 'critiques', 
                        'targetPrize', 'prizeAssessments', 'isPublic', 'publicId', 
                        'targetWordCount', 'publishing', 'updatedAt', 'primaryProvider',
                        'characters', 'plotNodes', 'chapters', 'research', 'sourceMaterials',
                        'lastModified', 'id', 'ownerId', 'createdAt',
                        'draftStage', 'draftPassHistory', 'cutMode',
                        'externalReviews', 'styleDNA', 'isLocked'
                      ]);

      allow delete: if isSignedIn() && isOwner(existing());

      // Sub-collections
      match /characters/{charId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.collaborators
        );
      }

      match /plotNodes/{nodeId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.collaborators
        );
      }

      match /chapters/{chapterId} {
        allow get, list: if isSignedIn() && (
          resource == null || 
          resource.data.get('ownerId', '') == request.auth.uid ||
          get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
        );
        allow write: if isSignedIn() && (
          incoming().get('ownerId', '') == request.auth.uid ||
          get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
        );
      }

      match /research/{noteId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.collaborators
        );
      }

      match /sourceMaterials/{sourceId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.collaborators
        );
      }

      match /presence/{userId} {
        allow read: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow write: if isSignedIn() && userId == request.auth.uid && 
                        canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
      }
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || 
                     exists(/databases/$(database)/documents/projects/$(request.auth.uid))); // Simplified check for collaborators
      allow write: if isSignedIn() && userId == request.auth.uid;
    }
  }
}
