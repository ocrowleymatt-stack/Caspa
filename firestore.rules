rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && (
        data.get('ownerId', '') == request.auth.uid ||
        data.get('ownerId', '') == request.auth.token.email
      );
    }

    function isCollaborator(data) {
      return isSignedIn() && (
        data.get('collaborators', []).hasAny([request.auth.uid]) ||
        data.get('collaborators', []).hasAny([request.auth.token.email])
      );
    }

    function canAccess(data) {
      return isOwner(data) || isCollaborator(data);
    }

    // Projects
    match /projects/{projectId} {
      // Individual doc reads: owner or collaborator only
      allow get: if canAccess(resource.data) || resource.data.get('isPublic', false) == true;

      // Queries: any signed-in user can run filtered queries
      // (client always queries by ownerId==uid or collaborators array-contains uid,
      //  so results are naturally scoped to that user's data)
      allow list: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.get('id', '') != '' &&
        request.resource.data.get('title', '') != '' &&
        (request.resource.data.get('ownerId', '') == request.auth.uid ||
         request.resource.data.get('ownerId', '') == request.auth.token.email);

      allow update: if isSignedIn() &&
        canAccess(resource.data) &&
        resource.data.get('ownerId', '') == request.resource.data.get('ownerId', '');

      allow delete: if isSignedIn() && isOwner(resource.data);

      match /characters/{id}   { allow read, write: if isSignedIn() && canAccess(get(/databases/$(database)/documents/projects/$(projectId)).data); }
      match /chapters/{id}     { allow read, write: if isSignedIn() && canAccess(get(/databases/$(database)/documents/projects/$(projectId)).data); }
      match /research/{id}     { allow read, write: if isSignedIn() && canAccess(get(/databases/$(database)/documents/projects/$(projectId)).data); }
      match /plotNodes/{id}    { allow read, write: if isSignedIn() && canAccess(get(/databases/$(database)/documents/projects/$(projectId)).data); }
      match /sourceMaterials/{id} { allow read, write: if isSignedIn() && canAccess(get(/databases/$(database)/documents/projects/$(projectId)).data); }
      match /presence/{uid}    { allow read: if isSignedIn(); allow write: if isSignedIn() && uid == request.auth.uid; }
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && userId == request.auth.uid;
    }

    // Global collections
    match /passes/{id}      { allow read, write: if isSignedIn(); }
    match /characters/{id}  { allow read, write: if isSignedIn(); }
    match /research/{id}    { allow read, write: if isSignedIn(); }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
