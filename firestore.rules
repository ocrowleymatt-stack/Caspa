rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(projectData) {
      return isSignedIn() && projectData.ownerId == request.auth.uid;
    }

    function isCollaborator(projectData) {
      return isSignedIn() && (projectData.ownerId == request.auth.uid || (projectData.keys().hasAll(['collaborators']) && request.auth.uid in projectData.collaborators));
    }

    // Helper to check if current user is the root owner based on project ID pattern
    function isImplicitOwner(projectId) {
      return isSignedIn() && (projectId == "project_" + request.auth.uid);
    }

    function canAccessProject(projectId, projectData) {
      return isImplicitOwner(projectId) || (projectData != null && isCollaborator(projectData));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function validateProject(data) {
      return data.title is string && data.title.size() <= 100 &&
             data.genre is string && data.genre.size() <= 64 &&
             data.ownerId == request.auth.uid &&
             data.collaborators is list && data.collaborators.size() <= 20 &&
             (data.createdAt is number || data.createdAt == request.time) &&
             (data.lastModified is number || data.lastModified == request.time || data.updatedAt is number || data.updatedAt == request.time);
    }

    function validateCharacter(data) {
      return data.name is string && data.name.size() <= 128 &&
             data.role is string && data.traits is list &&
             (data.updatedAt is number || data.updatedAt == request.time);
    }

    function validateChapter(data) {
      return data.title is string && data.title.size() <= 256 &&
             data.order is int && (data.updatedAt is number || data.updatedAt == request.time);
    }

    function validatePlotNode(data) {
      return data.title is string && data.status in ['active', 'ended', 'resolved'] &&
             data.order is int && (data.updatedAt is number || data.updatedAt == request.time);
    }

    function validateSourceMaterial(data) {
      return data.name is string && data.name.size() <= 256 &&
             data.content is string && (data.updatedAt is number || data.updatedAt == request.time);
    }

    function validateResearchNote(data) {
      return data.title is string && data.title.size() <= 256 &&
             data.content is string && data.category is string &&
             (data.updatedAt is number || data.updatedAt == request.time);
    }

    function getProject(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    // Projects
    match /projects/{projectId} {
      allow get: if canAccessProject(projectId, resource.data);
      allow list: if canAccessProject(projectId, resource.data);
      allow create: if isSignedIn() && validateProject(incoming());
      allow update: if canAccessProject(projectId, existing()) && (
        (isOwner(existing()) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'genre', 'premise', 'tone', 'type', 'maturity', 'collaborators', 'lastModified', 'updatedAt', 'sourceMaterials']) && (incoming().lastModified is number || incoming().lastModified == request.time || incoming().updatedAt is number || incoming().updatedAt == request.time)) ||
        (!isOwner(existing()) && incoming().diff(existing()).affectedKeys().hasOnly(['lastModified', 'updatedAt']) && (incoming().lastModified is number || incoming().lastModified == request.time || incoming().updatedAt is number || incoming().updatedAt == request.time)) ||
        (isImplicitOwner(projectId) && (incoming().lastModified is number || incoming().lastModified == request.time || incoming().updatedAt is number || incoming().updatedAt == request.time))
      );
      allow delete: if isOwner(existing()) || isImplicitOwner(projectId);

      // Source Materials
      match /sourceMaterials/{sourceId} {
        allow read: if canAccessProject(projectId, getProject(projectId));
        allow create, update: if canAccessProject(projectId, getProject(projectId)) && validateSourceMaterial(incoming());
        allow delete: if canAccessProject(projectId, getProject(projectId));
      }

      // Characters
      match /characters/{characterId} {
        allow read: if canAccessProject(projectId, getProject(projectId));
        allow create: if canAccessProject(projectId, getProject(projectId)) && validateCharacter(incoming());
        allow update: if canAccessProject(projectId, getProject(projectId)) && validateCharacter(incoming()) && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'backstory', 'traits', 'goals', 'fears', 'motivations', 'quirks', 'archetype', 'updatedAt']);
        allow delete: if canAccessProject(projectId, getProject(projectId));
      }

      // Plot Nodes
      match /plotNodes/{nodeId} {
        allow read: if canAccessProject(projectId, getProject(projectId));
        allow create: if canAccessProject(projectId, getProject(projectId)) && validatePlotNode(incoming());
        allow update: if canAccessProject(projectId, getProject(projectId)) && validatePlotNode(incoming()) &&
                         (projectHasNodeWriteAccess(projectId));
        allow delete: if canAccessProject(projectId, getProject(projectId));
      }
      
      function projectHasNodeWriteAccess(projectId) {
        let projectData = getProject(projectId);
        return projectData != null && (existing().status != 'resolved' || isOwner(projectData));
      }

      // Chapters
      match /chapters/{chapterId} {
        allow read: if canAccessProject(projectId, getProject(projectId));
        allow create: if canAccessProject(projectId, getProject(projectId)) && validateChapter(incoming());
        allow update: if canAccessProject(projectId, getProject(projectId)) && validateChapter(incoming());
        allow delete: if canAccessProject(projectId, getProject(projectId));

        // Comments
        match /comments/{commentId} {
          allow read: if canAccessProject(projectId, getProject(projectId));
          allow create: if canAccessProject(projectId, getProject(projectId)) && incoming().authorId == request.auth.uid;
          allow update: if canAccessProject(projectId, getProject(projectId)) && (incoming().authorId == request.auth.uid || isOwner(getProject(projectId)));
          allow delete: if canAccessProject(projectId, getProject(projectId)) && (existing().authorId == request.auth.uid || isOwner(getProject(projectId)));
        }
      }

      // Research
      match /research/{noteId} {
        allow read: if canAccessProject(projectId, getProject(projectId));
        allow create, update: if canAccessProject(projectId, getProject(projectId)) && validateResearchNote(incoming());
        allow delete: if canAccessProject(projectId, getProject(projectId));
      }

      // Presence
      match /presence/{userId} {
        allow read: if canAccessProject(projectId, getProject(projectId));
        allow write: if isSignedIn() && request.auth.uid == userId && incoming().userId == request.auth.uid;
      }
    }
  }
}
