rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(projectData) {
      return isSignedIn() && projectData.ownerId == request.auth.uid;
    }

    function isCollaborator(projectData) {
      return isSignedIn() && (request.auth.uid in projectData.collaborators);
    }

    function canAccessProject(projectData) {
      return isOwner(projectData) || isCollaborator(projectData);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidProject(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             (data.collaborators == null || data.collaborators is list) &&
             (data.isPublic == null || data.isPublic is bool);
    }

    function isValidChapter(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 1048576 && // 1MB limit check
             data.order is number;
    }

    // --- Rules ---

    // Projects
    match /projects/{projectId} {
      allow get: if isSignedIn() && (isOwner(existing()) || isCollaborator(existing())) || existing().isPublic == true;
      allow list: if isSignedIn() && (existing().ownerId == request.auth.uid || request.auth.uid in existing().collaborators);
      
      allow create: if isSignedIn() && 
                      isValidId(projectId) &&
                      isValidProject(incoming()) &&
                      incoming().ownerId == request.auth.uid &&
                      incoming().createdAt is number;

      allow update: if isSignedIn() &&
                      isValidProject(incoming()) &&
                      isOwner(existing()) &&
                      incoming().ownerId == existing().ownerId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'title', 'type', 'maturity', 'genre', 'premise', 'tone', 
                        'collaborators', 'lastModified', 'stats', 'critiques', 
                        'targetPrize', 'prizeAssessments', 'sourceMaterials', 
                        'externalReviews', 'isPublic', 'publicId', 'targetWordCount',
                        'publishing', 'updatedAt'
                      ]);

      allow delete: if isSignedIn() && isOwner(existing());

      // Sub-collections
      match /characters/{charId} {
        allow read: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow write: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
      }

      match /plotNodes/{nodeId} {
        allow read: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow write: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
      }

      match /chapters/{chapterId} {
        allow get, list: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data) || 
                            get(/databases/$(database)/documents/projects/$(projectId)).data.isPublic == true;
        allow write: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
      }

      match /research/{noteId} {
        allow read: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow write: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
      }

      match /sourceMaterials/{sourceId} {
        allow read: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow write: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
      }

      match /presence/{userId} {
        allow read: if canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow write: if isSignedIn() && userId == request.auth.uid && 
                        canAccessProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
      }
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || 
                     exists(/databases/$(database)/documents/projects/$(request.auth.uid))); // Simplified check for collaborators
      allow write: if isSignedIn() && userId == request.auth.uid;
    }
  }
}
