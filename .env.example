PORT=3000
DATA_DIR=./data
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
DROPBOX_TOKEN=
BACKUP_DIR=./backups
LOG_LEVEL=info

# Authentication (set AUTH_ENABLED=true for multi-user mode)
AUTH_ENABLED=true
# Generate a strong secret: openssl rand -hex 32
AUTH_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_EXPIRES_IN=604800

# First-run bootstrap admin (created automatically when no users exist)
ADMIN_EMAIL=admin@caspa.local
ADMIN_PASSWORD=changeme
