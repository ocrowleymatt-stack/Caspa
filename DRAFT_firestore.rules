rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    // Note: We use isSignedIn() instead of isVerified() right now because standard Google SignIn 
    // usually yields verified email, but we don't strictly mandate verified emails if not fully required
    // Actually wait, specification says: "You MUST strictly mandate that the user is verified using request.auth.token.email_verified == true."
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    // Check Project ownership
    function isOwner() {
      return existing().ownerId == request.auth.uid;
    }
    function ownsProjectPath(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    // Validation definitions
    function isValidProject(data) {
      return data.keys().hasAll(['title', 'ownerId', 'lastModified', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.ownerId is string && data.ownerId == request.auth.uid &&
             data.lastModified is number &&
             data.createdAt is number &&
             data.get('type', '') is string &&
             data.get('maturity', '') is string &&
             data.get('genre', '') is string &&
             data.get('premise', '') is string &&
             data.get('tone', '') is string &&
             (data.get('collaborators', []) is list && data.get('collaborators', []).size() <= 50) &&
             (data.get('stats', {}) is map) &&
             (data.get('critiques', {}) is map);
    }

    function isValidCharacter(data) {
      return data.keys().hasAll(['name', 'role', 'updatedAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.role is string && data.role.size() <= 100 &&
             data.get('backstory', '') is string && data.get('backstory', '').size() <= 10000 &&
             (data.get('traits', []) is list) &&
             (data.get('goals', []) is list) &&
             (data.get('fears', []) is list) &&
             (data.get('motivations', []) is list) &&
             (data.get('quirks', []) is list) &&
             data.get('archetype', '') is string &&
             data.updatedAt is number;
    }

    function isValidPlotNode(data) {
      return data.keys().hasAll(['title', 'status', 'order']) &&
             data.title is string && data.title.size() <= 200 &&
             data.get('description', '') is string && data.get('description', '').size() <= 5000 &&
             data.status in ['active', 'ended', 'resolved'] &&
             data.get('type', 'main') in ['main', 'sub', 'theme'] &&
             data.order is number &&
             data.get('updatedAt', 0) is number;
    }

    function isValidChapter(data) {
      return data.keys().hasAll(['title', 'order', 'updatedAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.get('summary', '') is string && data.get('summary', '').size() <= 5000 &&
             data.get('content', '') is string && data.get('content', '').size() <= 1000000 &&
             data.order is number &&
             (data.get('plotNodeIds', []) is list && data.get('plotNodeIds', []).size() <= 50) &&
             (data.get('tags', []) is list && data.get('tags', []).size() <= 50) &&
             data.updatedAt is number;
    }

    function isValidResearchNote(data) {
      return data.keys().hasAll(['title', 'content', 'updatedAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 1000000 &&
             data.get('source', '') is string && data.get('source', '').size() <= 2000 &&
             (data.get('sources', []) is list && data.get('sources', []).size() <= 50) &&
             data.get('category', '') is string && data.get('category', '').size() <= 100 &&
             (data.get('tags', []) is list && data.get('tags', []).size() <= 50) &&
             data.updatedAt is number;
    }

    function isValidSourceMaterial(data) {
      return data.keys().hasAll(['name', 'content', 'updatedAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.content is string && data.content.size() <= 1000000 &&
             data.get('type', '') is string && data.get('type', '').size() <= 50 &&
             data.updatedAt is number;
    }

    function isValidPresence(data) {
      return data.keys().hasAll(['userId', 'lastSeen']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.get('userName', '') is string && data.get('userName', '').size() <= 100 &&
             data.get('cursorPosition', 0) is number &&
             data.get('activeChapterId', '') is string && data.get('activeChapterId', '').size() <= 128 &&
             data.lastSeen is number;
    }

    match /projects/{projectId} {
      allow get: if isVerified() && isValidId(projectId) && isOwner();
      allow list: if isVerified() && existing().ownerId == request.auth.uid;
      
      allow create: if isVerified() && 
                    isValidId(projectId) && 
                    isValidProject(incoming()) && 
                    incoming().keys().size() <= 12;

      allow update: if isVerified() &&
                    isValidId(projectId) &&
                    isOwner() &&
                    isValidProject(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'title', 'type', 'maturity', 'genre', 'premise', 'tone', 'collaborators', 'lastModified', 'stats', 'critiques'
                    ]);

      allow delete: if isVerified() && isValidId(projectId) && isOwner();

      match /characters/{characterId} {
        allow get: if isVerified() && isValidId(characterId) && ownsProjectPath(projectId);
        allow list: if isVerified() && ownsProjectPath(projectId);
        
        allow create: if isVerified() && 
                      isValidId(characterId) && 
                      ownsProjectPath(projectId) &&
                      isValidCharacter(incoming()) &&
                      incoming().keys().size() <= 10;
                      
        allow update: if isVerified() && 
                      isValidId(characterId) && 
                      ownsProjectPath(projectId) &&
                      isValidCharacter(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'name', 'role', 'backstory', 'traits', 'goals', 'fears', 'motivations', 'quirks', 'archetype', 'updatedAt'
                      ]);
                      
        allow delete: if isVerified() && isValidId(characterId) && ownsProjectPath(projectId);
      }

      match /plotNodes/{nodeId} {
        allow get: if isVerified() && isValidId(nodeId) && ownsProjectPath(projectId);
        allow list: if isVerified() && ownsProjectPath(projectId);
        
        allow create: if isVerified() && 
                      isValidId(nodeId) && 
                      ownsProjectPath(projectId) &&
                      isValidPlotNode(incoming()) &&
                      incoming().keys().size() <= 6;
                      
        allow update: if isVerified() && 
                      isValidId(nodeId) && 
                      ownsProjectPath(projectId) &&
                      isValidPlotNode(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'title', 'description', 'status', 'type', 'order', 'updatedAt'
                      ]);
                      
        allow delete: if isVerified() && isValidId(nodeId) && ownsProjectPath(projectId);
      }

      match /chapters/{chapterId} {
        allow get: if isVerified() && isValidId(chapterId) && ownsProjectPath(projectId);
        allow list: if isVerified() && ownsProjectPath(projectId);
        
        allow create: if isVerified() && 
                      isValidId(chapterId) && 
                      ownsProjectPath(projectId) &&
                      isValidChapter(incoming()) &&
                      incoming().keys().size() <= 7;
                      
        allow update: if isVerified() && 
                      isValidId(chapterId) && 
                      ownsProjectPath(projectId) &&
                      isValidChapter(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'title', 'summary', 'content', 'order', 'plotNodeIds', 'tags', 'updatedAt'
                      ]);
                      
        allow delete: if isVerified() && isValidId(chapterId) && ownsProjectPath(projectId);
      }

      match /research/{noteId} {
        allow get: if isVerified() && isValidId(noteId) && ownsProjectPath(projectId);
        allow list: if isVerified() && ownsProjectPath(projectId);
        
        allow create: if isVerified() && 
                      isValidId(noteId) && 
                      ownsProjectPath(projectId) &&
                      isValidResearchNote(incoming()) &&
                      incoming().keys().size() <= 7;
                      
        allow update: if isVerified() && 
                      isValidId(noteId) && 
                      ownsProjectPath(projectId) &&
                      isValidResearchNote(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'title', 'content', 'source', 'sources', 'category', 'tags', 'updatedAt'
                      ]);
                      
        allow delete: if isVerified() && isValidId(noteId) && ownsProjectPath(projectId);
      }
      
      match /sourceMaterials/{sourceId} {
        allow get: if isVerified() && isValidId(sourceId) && ownsProjectPath(projectId);
        allow list: if isVerified() && ownsProjectPath(projectId);
        
        allow create: if isVerified() && 
                      isValidId(sourceId) && 
                      ownsProjectPath(projectId) &&
                      isValidSourceMaterial(incoming()) &&
                      incoming().keys().size() <= 4;
                      
        allow update: if isVerified() && 
                      isValidId(sourceId) && 
                      ownsProjectPath(projectId) &&
                      isValidSourceMaterial(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'name', 'content', 'type', 'updatedAt'
                      ]);
                      
        allow delete: if isVerified() && isValidId(sourceId) && ownsProjectPath(projectId);
      }
      
      match /presence/{userId} {
        allow get: if isVerified() && isValidId(userId) && ownsProjectPath(projectId);
        allow list: if isVerified() && ownsProjectPath(projectId);
        
        allow create: if isVerified() && 
                      isValidId(userId) && 
                      ownsProjectPath(projectId) &&
                      isValidPresence(incoming()) &&
                      incoming().keys().size() <= 5;
                      
        allow update: if isVerified() && 
                      isValidId(userId) && 
                      ownsProjectPath(projectId) &&
                      isValidPresence(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'userName', 'cursorPosition', 'activeChapterId', 'lastSeen'
                      ]);
                      
        allow delete: if isVerified() && isValidId(userId) && (userId == request.auth.uid || ownsProjectPath(projectId));
      }
    }
  }
}
